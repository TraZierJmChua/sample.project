<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Advanced To-Do List</title>

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f4f4f9;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        transition: 0.3s;
    }

    .container {
        background: white;
        padding: 25px;
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        width: 400px;
        transition: 0.3s;
    }

    h1 {
        text-align: center;
        color: #333;
    }

    .input-group {
        display: flex;
        margin-bottom: 15px;
    }

    input[type="text"] {
        flex: 1;
        padding: 10px;
        font-size: 16px;
        border: 1px solid #ccc;
        border-radius: 6px;
    }

    button {
        margin-left: 5px;
        padding: 10px 15px;
        border: none;
        background: #4CAF50;
        color: white;
        border-radius: 6px;
        cursor: pointer;
    }

    button:hover {
        opacity: 0.9;
    }

    .delete {
        background: #e74c3c;
    }

    .clear {
        background: #ff9800;
    }

    .dark-btn {
        background: #333;
        margin-top: 10px;
        width: 100%;
    }

    ul {
        list-style: none;
        padding: 0;
    }

    li {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #f8f8f8;
        padding: 10px;
        margin-bottom: 8px;
        border-radius: 6px;
    }

    .task {
        display: flex;
        align-items: center;
        gap: 10px;
        flex: 1;
    }

    li.completed span {
        text-decoration: line-through;
        color: gray;
    }

    .stats {
        display: flex;
        justify-content: space-between;
        margin-bottom: 15px;
        font-weight: bold;
    }

    .dark {
        background: #222;
        color: white;
    }

    .dark .container {
        background: #333;
        color: white;
    }

    .dark li {
        background: #444;
    }

    .dark h1 {
        color: white;
    }
</style>
</head>

<body>

<div class="container">

    <h1>📝 To-Do List</h1>

    <div class="stats">
        <span id="taskCount">Tasks: 0</span>
        <span id="completedCount">Completed: 0</span>
    </div>

    <div class="input-group">
        <input type="text" id="taskInput" placeholder="Enter a task...">
        <button onclick="addTask()">Add</button>
    </div>

    <button class="clear" onclick="clearTasks()">Clear All</button>

    <ul id="taskList"></ul>

    <button class="dark-btn" onclick="toggleDarkMode()">
        🌙 Dark Mode
    </button>

</div>

<script>

function updateCounts() {
    const tasks =
        document.querySelectorAll("#taskList li").length;

    const completed =
        document.querySelectorAll("#taskList li.completed").length;

    document.getElementById("taskCount").textContent =
        "Tasks: " + tasks;

    document.getElementById("completedCount").textContent =
        "Completed: " + completed;
}

function saveTasks() {
    localStorage.setItem(
        "taskData",
        document.getElementById("taskList").innerHTML
    );
}

function attachEvents(li) {

    const checkbox =
        li.querySelector("input[type='checkbox']");

    checkbox.addEventListener("change", function() {
        li.classList.toggle("completed", this.checked);
        updateCounts();
        saveTasks();
    });

    li.querySelector(".delete").addEventListener("click", function() {
        li.remove();
        updateCounts();
        saveTasks();
    });
}

function addTask() {

    const input =
        document.getElementById("taskInput");

    const taskText =
        input.value.trim();

    if (taskText === "") return;

    const li = document.createElement("li");

    li.innerHTML = `
        <div class="task">
            <input type="checkbox">
            <span>${taskText}</span>
        </div>
        <button class="delete">Delete</button>
    `;

    attachEvents(li);

    document.getElementById("taskList")
        .appendChild(li);

    input.value = "";
    input.focus();

    updateCounts();
    saveTasks();
}

function clearTasks() {
    document.getElementById("taskList").innerHTML = "";
    updateCounts();
    saveTasks();
}

function toggleDarkMode() {
    document.body.classList.toggle("dark");
}

document.getElementById("taskInput")
.addEventListener("keypress", function(event) {

    if (event.key === "Enter") {
        addTask();
    }

});

window.onload = function() {

    const saved =
        localStorage.getItem("taskData");

    if (saved) {

        document.getElementById("taskList").innerHTML = saved;

        document.querySelectorAll("#taskList li")
            .forEach(attachEvents);
    }

    updateCounts();
};

</script>

</body>
</html>
